# Copy this file to client/server/.env and fill in your local values.
# The app loads client/server/.env automatically — this file is reference only.

PORT=3000

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=aptspace

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Default password for seeded demo users (admin@aptspace.com, etc.)
DEFAULT_PASSWORD=password

# CORS — comma-separated origins, or leave blank for local defaults
ALLOWED_ORIGIN=http://localhost:3000

# App URL (used in password-reset links)
APP_URL=http://localhost:3000

# SMTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@aptspace.com
