# Copy this file to client/server/.env and fill in your local values.
# The app loads client/server/.env automatically — this file is reference only.

PORT=3000

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=aptspace

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Default password for seeded demo users (admin@aptspace.com, etc.)
DEFAULT_PASSWORD=password

# CORS — comma-separated origins, or leave blank for local defaults
ALLOWED_ORIGIN=http://localhost:3000

# Email (optional — not wired yet)
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=noreply@aptspace.com
