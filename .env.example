# Copy this file to client/server/.env and fill in your local values.
# The app loads client/server/.env automatically — this file is reference only.
#
# Local dev:     npm run setup  →  npm run dev
# Staging prep:  npm run setup:staging  →  edit client/server/.env.staging (separate file)

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── MySQL ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=aptspace
# Set true when connecting to managed/cloud MySQL over TLS
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false
DB_CONNECTION_LIMIT=10

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Only used when ENABLE_SEED=true (first deploy) — never use "password" in production
DEFAULT_PASSWORD=password

# Comma-separated browser origins allowed to call the API (required in production)
ALLOWED_ORIGIN=http://localhost:3000

# Public URL of the app (password-reset links) — use https:// in production
APP_URL=http://localhost:3000

# ── Performance / abuse protection ──────────────────────────────────────────
# In-memory cache for catalog/rates endpoints (reduces DB load under traffic)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=120
CACHE_MAX_ENTRIES=500
# General API requests per IP per minute (auth routes also have a stricter limit)
API_RATE_LIMIT_MAX=600

# ── Bootstrap (production) ───────────────────────────────────────────────────
# First deploy only: create default admin users if missing
# ENABLE_SEED=true
# Load demo bookings — never enable on a live production DB
# ENABLE_DEMO_DATA=false

# ── SMTP email ──────────────────────────────────────────────────────────────
# Leave as placeholders below for local dev — emails are logged to the server console instead.
# For real delivery use APTS mail or MailHog (SMTP_HOST=localhost, SMTP_PORT=1025).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@aptspace.com
# Guest support messages are delivered here (defaults to SMTP_USER or facilities@apts.edu.ph)
SUPPORT_EMAIL=facilities@apts.edu.ph
