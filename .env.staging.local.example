# LOCAL staging practice — test production mode on your machine.
# Setup:  npm run setup:staging:local
# Run:    npm run start:staging:local
#
# Uses a separate DB name so you don't touch your dev data.
# Create the DB once:  mysql -u root -p -e "CREATE DATABASE IF NOT EXISTS aptspace_staging;"

NODE_ENV=production
PORT=3001
HOST=0.0.0.0

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=aptspace_staging
DB_SSL=false
DB_CONNECTION_LIMIT=10

# Use a different secret than dev — generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=local_staging_practice_replace_with_generated_secret_min_32_chars
JWT_EXPIRES_IN=7d

DEFAULT_PASSWORD=password

APP_URL=http://localhost:3001
ALLOWED_ORIGIN=http://localhost:3001

# First run only — creates admin users, then comment out:
ENABLE_SEED=true
# Demo data for UAT practice in prod mode:
ENABLE_DEMO_DATA=true

# SMTP optional for local — password reset emails will fail silently without it
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM=noreply@localhost
