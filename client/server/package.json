{
  "name": "aptspace-server",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --import ./test/helpers/bootstrap.mjs --test --test-concurrency=1 \"test/**/*.test.js\"",
    "test:unit": "node --import ./test/helpers/bootstrap.mjs --test \"test/unit/*.test.js\"",
    "test:integration": "node --import ./test/helpers/bootstrap.mjs --test --test-concurrency=1 \"test/integration/*.test.js\"",
    "test:smoke": "node --import ./test/helpers/bootstrap.mjs --test test/integration/pages.smoke.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.5",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "supertest": "^7.1.1"
  }
}
