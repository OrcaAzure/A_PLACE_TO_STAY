# Staging environment template for APTS servers.
# On the staging server:  cp .env.staging.example client/server/.env
# Locally (optional):      npm run setup:staging  → fills client/server/.env.staging
# Test production mode locally: npm run start:staging  (uses .env.staging, not .env)
#
# Your daily dev workflow is unchanged:  npm run dev  → uses client/server/.env

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── MySQL (from APTS IT) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=aptspace_app
DB_PASSWORD=ASK_IT_FOR_PASSWORD
DB_NAME=aptspace_staging
DB_SSL=false
DB_CONNECTION_LIMIT=10

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate a NEW secret for staging — never reuse your local dev secret
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GENERATE_A_NEW_48_CHAR_OR_LONGER_SECRET
JWT_EXPIRES_IN=7d

# Strong password for first-time admin bootstrap only (ENABLE_SEED=true once)
DEFAULT_PASSWORD=CHANGE_ME_BEFORE_FIRST_BOOTSTRAP

# ── URLs (from APTS IT — use https) ─────────────────────────────────────────
APP_URL=https://aptspace-staging.apts.edu
ALLOWED_ORIGIN=https://aptspace-staging.apts.edu

# ── First deploy on staging only ────────────────────────────────────────────
# Uncomment for the very first staging boot, then remove after admin login works:
# ENABLE_SEED=true
#
# Optional demo bookings for UAT (never use on production):
# ENABLE_DEMO_DATA=true

# ── SMTP (from APTS IT) ─────────────────────────────────────────────────────
SMTP_HOST=mail.apts.edu
SMTP_PORT=587
SMTP_USER=ASK_IT
SMTP_PASS=ASK_IT
SMTP_FROM=noreply@apts.edu
