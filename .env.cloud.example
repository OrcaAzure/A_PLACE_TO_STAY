# Cloud VM template (Oracle Cloud free tier, etc.)
# On the server after git clone:
#   cp .env.cloud.example client/server/.env
#   nano client/server/.env   ← set PUBLIC_IP and secrets
#
# Or locally: npm run setup:cloud

NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# On a single VM, MySQL runs on the same machine:
DB_HOST=127.0.0.1
DB_USER=aptspace_app
DB_PASSWORD=SET_STRONG_PASSWORD_HERE
DB_NAME=aptspace
DB_SSL=false
DB_CONNECTION_LIMIT=10

# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GENERATE_48_CHAR_HEX_SECRET
JWT_EXPIRES_IN=7d
DEFAULT_PASSWORD=CHANGE_AFTER_FIRST_LOGIN

# Replace YOUR_PUBLIC_IP with the VM's public IP from Oracle dashboard
APP_URL=http://YOUR_PUBLIC_IP:3000
ALLOWED_ORIGIN=http://YOUR_PUBLIC_IP:3000

# First deploy only — then remove:
ENABLE_SEED=true
ENABLE_DEMO_DATA=true

# Optional until you configure real mail:
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aptspace.com
